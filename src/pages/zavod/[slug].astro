---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { terrainLabels, terrainDotColors } from '../../lib/types';
import { getRaceBySlug } from '../../lib/supabase';
import CompletenessBadge from '../../components/CompletenessBadge.astro';
import { getCompleteness } from '../../lib/completeness';

const { slug } = Astro.params;
if (!slug) {
  return new Response(null, { status: 404 });
}

const race = await getRaceBySlug(slug);

if (!race) {
  return new Response(null, { status: 404 });
}

const dateFormatted = new Date(race.date_start).toLocaleDateString('cs-CZ', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const dateEndFormatted = race.date_end
  ? new Date(race.date_end).toLocaleDateString('cs-CZ', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const priceText =
  race.price_from !== null && race.price_to !== null
    ? `${race.price_from}–${race.price_to} Kč`
    : race.price_from !== null
      ? race.price_from === 0
        ? 'Zdarma'
        : `od ${race.price_from} Kč`
      : 'Neuvedeno';

const completeness = getCompleteness(race);
---

<BaseLayout
  title={race.name}
  description={race.description ?? `${race.name} — ${dateFormatted} v ${race.city}`}
  canonical={`https://zavodyvcr.cz/zavod/${race.slug}`}
>
  <article class="mx-auto max-w-[960px] px-8 py-16 max-md:px-4">
    <!-- Breadcrumb -->
    <nav class="mb-10 font-mono text-xs uppercase tracking-[0.06em] text-text-secondary">
      <a href="/zavody" class="hover:text-accent transition-colors duration-150">Závody</a>
      <span class="mx-2 text-border">/</span>
      <span class="text-text normal-case">{race.name}</span>
    </nav>

    <!-- Header -->
    <div>
      <div class="flex items-center justify-between gap-4">
        <h1 class="font-serif text-[2.5rem] text-primary leading-tight max-md:text-[2rem]">
          {race.name}
        </h1>
        <div class="flex shrink-0 flex-col items-end gap-2">
          <div class="flex items-center gap-2">
            <span class={`h-2.5 w-2.5 rounded-full ${terrainDotColors[race.terrain] ?? terrainDotColors.mixed}`}></span>
            <span class="font-mono text-xs font-medium uppercase tracking-[0.06em] text-text-secondary">
              {terrainLabels[race.terrain] ?? race.terrain}
            </span>
          </div>
          <CompletenessBadge race={race} showLabel />
        </div>
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <span class="font-mono text-sm text-text-secondary">
          {dateFormatted}
          {dateEndFormatted && ` – ${dateEndFormatted}`}
        </span>
        {race.time_start && (
          <span class="font-mono text-sm font-semibold text-text">
            Start {race.time_start}
          </span>
        )}
      </div>
      <p class="mt-2 font-mono text-sm text-text-secondary">
        {race.city}{race.region && race.region !== race.city ? `, ${race.region}` : ''}
      </p>
    </div>

    <hr class="mt-10 border-border" />

    <!-- Key Info Grid -->
    <div class="grid grid-cols-2 border-b border-border sm:grid-cols-4">
      <div class="border-r border-border p-6 max-sm:border-b max-sm:border-r-0 max-sm:[&:nth-child(odd)]:border-r max-sm:[&:nth-child(odd)]:border-border">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Vzdálenosti</p>
        <div class="mt-3 space-y-1">
          {race.distances.length > 0 ? (
            race.distances.map((d) => (
              <p class="font-mono text-sm font-semibold text-text">
                {d.km ? `${d.label} (${d.km} km)` : d.label}
              </p>
            ))
          ) : (
            <p class="font-mono text-sm font-semibold text-text-secondary">
              Neuvedeno
            </p>
          )}
        </div>
      </div>
      <div class="border-r border-border p-6 max-sm:border-b">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Startovné</p>
        <p class="mt-3 font-mono text-sm font-semibold text-text">{priceText}</p>
      </div>
      {race.elevation_gain && (
        <div class="border-r border-border p-6 max-sm:border-r-0">
          <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Převýšení</p>
          <p class="mt-3 font-mono text-sm font-semibold text-text">{race.elevation_gain} m D+</p>
        </div>
      )}
      {race.capacity && (
        <div class="p-6">
          <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Kapacita</p>
          <p class="mt-3 font-mono text-sm font-semibold text-text">{race.capacity.toLocaleString('cs-CZ')} míst</p>
        </div>
      )}
    </div>

    <!-- Description -->
    {race.description && (
      <div class="mt-12">
        <h2 class="font-mono text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">O závodu</h2>
        <p class="mt-4 max-w-2xl text-base text-text leading-relaxed">{race.description}</p>
      </div>
    )}

    <!-- Action Buttons -->
    <div class="mt-12 flex flex-wrap gap-4">
      {race.registration_url && (
        <a
          href={race.registration_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
        >
          Registrace
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      )}
      {race.website && (
        <a
          href={race.website}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-border px-8 py-3.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-text transition-colors duration-150 hover:border-primary hover:text-primary"
        >
          Web závodu
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      )}
    </div>

    <!-- Growth Loop: "Běžím!" -->
    <div class="mt-8 border border-border"
      id="growth-section"
      data-race-id={race.id}
      data-race-name={race.name}
      data-race-slug={race.slug}
    >
      <!-- "Běžím!" main CTA -->
      <div class="flex items-center justify-between border-b border-border px-6 py-5">
        <div class="flex items-center gap-4">
          <button
            type="button"
            id="bezim-btn"
            class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-2.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-primary-light"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.841m2.699-11.592L3.75 21.75" />
            </svg>
            <span id="bezim-label">Přidat do mých závodů</span>
          </button>
        </div>
        <!-- Copy link -->
        <button
          type="button"
          id="copy-link-btn"
          class="hidden items-center gap-2 font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent sm:inline-flex"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
          </svg>
          <span id="copy-link-label">Kopírovat odkaz</span>
        </button>
      </div>

      <!-- Share options (revealed after "Běžím!" click) -->
      <div id="share-row" class="hidden border-t border-border px-6 py-4">
        <p class="mb-3 font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Dej vědět kamarádům</p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            id="share-whatsapp"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-border px-4 py-2 font-mono text-[11px] font-medium uppercase tracking-[0.06em] text-text transition-colors duration-150 hover:border-primary hover:text-primary"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a
            id="share-facebook"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-border px-4 py-2 font-mono text-[11px] font-medium uppercase tracking-[0.06em] text-text transition-colors duration-150 hover:border-primary hover:text-primary"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
          <a
            id="share-twitter"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-border px-4 py-2 font-mono text-[11px] font-medium uppercase tracking-[0.06em] text-text transition-colors duration-150 hover:border-primary hover:text-primary"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <button
            type="button"
            id="copy-link-btn-mobile"
            class="inline-flex items-center gap-2 border border-border px-4 py-2 font-mono text-[11px] font-medium uppercase tracking-[0.06em] text-text transition-colors duration-150 hover:border-primary hover:text-primary sm:hidden"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
            <span id="copy-link-label-mobile">Odkaz</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Organizer -->
    {race.organizer && (
      <div class="mt-12 border border-border p-6">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Pořadatel</p>
        <p class="mt-2 text-base font-medium text-text">
          {race.organizer_url ? (
            <a href={race.organizer_url} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-[#D4552F] transition-colors duration-150">
              {race.organizer}
            </a>
          ) : (
            race.organizer
          )}
        </p>
      </div>
    )}

    <!-- Completeness info bar -->
    <div class="mt-12 flex items-center justify-between border border-border p-5">
      <div class="flex items-center gap-3">
        <CompletenessBadge race={race} showLabel />
        <span class="font-mono text-[11px] text-text-secondary">({completeness.score} %)</span>
      </div>
      <button
        type="button"
        id="report-btn"
        class="inline-flex items-center gap-2 font-mono text-xs text-text-secondary hover:text-accent transition-colors duration-150"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5" />
        </svg>
        Nahlásit chybu
      </button>
    </div>

    <!-- Report modal -->
    <div
      id="report-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40"
      data-race-id={race.id}
    >
      <div class="mx-4 w-full max-w-md border border-border bg-surface p-8">
        <h3 class="font-mono text-sm font-semibold uppercase tracking-[0.06em] text-primary">Nahlásit chybu</h3>
        <p class="mt-2 text-sm text-text-secondary">Něco nesedí? Dejte nám vědět.</p>

        <form id="report-form" class="mt-6 space-y-4">
          <fieldset id="report-reasons-fieldset">
            <legend class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary mb-3">Co je špatně?</legend>
            <div class="space-y-2">
              {['Špatné datum', 'Špatný popis', 'Závod zrušen', 'Špatná cena', 'Špatná lokace', 'Jiné'].map((reason) => (
                <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
                  <input type="checkbox" name="reasons" value={reason} class="accent-accent h-4 w-4" />
                  {reason}
                </label>
              ))}
            </div>
            <p class="field-error-msg" id="report-reasons-error">&nbsp;</p>
          </fieldset>

          <div id="report-message-field">
            <label class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary" for="report-message">
              Zpráva (volitelné)
            </label>
            <textarea
              id="report-message"
              name="message"
              rows="3"
              class="mt-2 w-full border border-border bg-bg p-3 text-sm text-text placeholder:text-text-secondary/60 focus:border-accent focus:outline-none"
              placeholder="Upřesněte, co je špatně..."
            ></textarea>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <button
              type="submit"
              id="report-submit"
              class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-2.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F] disabled:opacity-50"
            >
              Odeslat
            </button>
            <button
              type="button"
              id="report-cancel"
              class="font-mono text-xs text-text-secondary hover:text-text transition-colors duration-150"
            >
              Zrušit
            </button>
          </div>

          <p id="report-status" class="hidden font-mono text-xs"></p>
        </form>
      </div>
    </div>

    <!-- Back -->
    <hr class="mt-8 border-border" />
    <div class="mt-8">
      <a href="/zavody" class="font-mono text-xs text-accent hover:text-[#D4552F] transition-colors duration-150">
        &larr; Zpět na přehled závodů
      </a>
    </div>
  </article>

  <script>
    import { getClient } from '../../lib/auth';
    import { getUser, registerInterest, hasInterest, recordReferral } from '../../lib/auth';

    // --- Report modal ---
    const COOLDOWN_KEY = 'report_last_submitted';
    const COOLDOWN_MS = 60_000;

    const btn = document.getElementById('report-btn');
    const modal = document.getElementById('report-modal') as HTMLElement;
    const cancel = document.getElementById('report-cancel');
    const form = document.getElementById('report-form') as HTMLFormElement;
    const statusEl = document.getElementById('report-status') as HTMLElement;

    const raceId = modal?.dataset.raceId;

    btn?.addEventListener('click', () => {
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
    });

    function closeModal() {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
    }

    cancel?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    const reasonsFieldset = document.getElementById('report-reasons-fieldset') as HTMLElement;
    const reasonsError = document.getElementById('report-reasons-error') as HTMLElement;
    const submitBtnReport = document.getElementById('report-submit') as HTMLButtonElement;

    // Clear fieldset error when a checkbox is checked
    form?.querySelectorAll('input[name="reasons"]').forEach(cb => {
      cb.addEventListener('change', () => {
        reasonsFieldset.classList.remove('fieldset-error');
        statusEl.classList.add('hidden');
      });
    });

    // Clear fieldset error when message is typed
    document.getElementById('report-message')?.addEventListener('input', () => {
      reasonsFieldset.classList.remove('fieldset-error');
      statusEl.classList.add('hidden');
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous errors
      reasonsFieldset.classList.remove('fieldset-error');
      statusEl.classList.add('hidden');

      // Rate limit check
      const lastSubmitted = Number(localStorage.getItem(COOLDOWN_KEY) || 0);
      const elapsed = Date.now() - lastSubmitted;
      if (elapsed < COOLDOWN_MS) {
        const remaining = Math.ceil((COOLDOWN_MS - elapsed) / 1000);
        statusEl.textContent = `Nahlášení je možné jednou za minutu. Počkejte prosím ${remaining} sekund.`;
        statusEl.className = 'font-mono text-xs text-error';
        statusEl.classList.remove('hidden');
        return;
      }

      const formData = new FormData(form);
      const reasons = formData.getAll('reasons');
      const message = formData.get('message');

      if (reasons.length === 0 && !message) {
        reasonsFieldset.classList.add('fieldset-error');
        reasonsError.textContent = 'Vyberte alespoň jeden důvod, nebo napište zprávu do textového pole níže.';
        return;
      }

      submitBtnReport.disabled = true;

      try {
        const supabase = getClient();
        const { error } = await supabase.from('race_reports').insert({
          race_id: raceId,
          reasons: reasons,
          message: message || null,
        });

        if (error) throw error;

        localStorage.setItem(COOLDOWN_KEY, String(Date.now()));
        statusEl.textContent = 'Děkujeme za nahlášení! Chybu opravíme co nejdříve.';
        statusEl.className = 'font-mono text-xs text-success';
        statusEl.classList.remove('hidden');
        setTimeout(closeModal, 1500);
      } catch {
        statusEl.textContent = 'Nepodařilo se odeslat. Zkontrolujte připojení k internetu a zkuste to znovu.';
        statusEl.className = 'font-mono text-xs text-error';
        statusEl.classList.remove('hidden');
      } finally {
        submitBtnReport.disabled = false;
      }
    });

    // --- Growth loop: "Běžím!" (auth-gated) ---
    const growthSection = document.getElementById('growth-section') as HTMLElement;
    const raceName = growthSection?.dataset.raceName ?? '';
    const raceSlug = growthSection?.dataset.raceSlug ?? '';
    const growthRaceId = growthSection?.dataset.raceId ?? '';
    let currentCount = Number(growthSection?.dataset.interestCount ?? 0);

    const baseRaceUrl = `https://zavodyvcr.cz/zavod/${raceSlug}`;

    const bezimBtn = document.getElementById('bezim-btn') as HTMLButtonElement;
    const bezimLabel = document.getElementById('bezim-label') as HTMLElement;
    const shareRow = document.getElementById('share-row') as HTMLElement;
    // Store referral parameter from URL for later use
    const urlRef = new URLSearchParams(window.location.search).get('ref');
    if (urlRef) {
      sessionStorage.setItem('race_ref', urlRef);
    }

    // Get share URL with referral param if user is logged in
    async function getShareUrl(): Promise<string> {
      const user = await getUser();
      if (user) {
        return `${baseRaceUrl}?ref=${user.id}`;
      }
      return baseRaceUrl;
    }

    // Build share text dynamically with count
    function getShareText(): string {
      if (currentCount > 1) {
        return `Běžím ${raceName}! Už nás je ${currentCount}. Přidej se!`;
      }
      return `Běžím ${raceName}! Přidej se!`;
    }

    // Pre-fill social links
    async function updateShareLinks() {
      const raceUrl = await getShareUrl();
      const text = getShareText();
      const twitter = document.getElementById('share-twitter') as HTMLAnchorElement;
      const facebook = document.getElementById('share-facebook') as HTMLAnchorElement;
      const whatsapp = document.getElementById('share-whatsapp') as HTMLAnchorElement;

      twitter.href = `https://x.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(raceUrl)}`;
      facebook.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(raceUrl)}`;
      whatsapp.href = `https://wa.me/?text=${encodeURIComponent(`${text} ${raceUrl}`)}`;
    }
    updateShareLinks();

    // Check if user already registered interest and show confirmed state
    async function checkExistingInterest() {
      const alreadyInterested = await hasInterest(growthRaceId);
      if (alreadyInterested) {
        showConfirmedState();
      }
    }
    checkExistingInterest();

    function showConfirmedState() {
      bezimLabel.textContent = 'Běžím!';
      bezimBtn.classList.remove('bg-primary', 'hover:bg-primary-light');
      bezimBtn.classList.add('bg-accent', 'hover:bg-[#D4552F]');
      shareRow.classList.remove('hidden');
      updateShareLinks();
    }

    // "Běžím!" click handler — requires auth
    bezimBtn?.addEventListener('click', async () => {
      const user = await getUser();

      if (!user) {
        // Not logged in — open auth modal with "bezim" intent
        document.dispatchEvent(new CustomEvent('open-auth-modal', {
          detail: { intent: 'bezim', raceId: growthRaceId }
        }));
        return;
      }

      // User is authenticated — register interest
      const alreadyInterested = await hasInterest(growthRaceId);
      if (!alreadyInterested) {
        try {
          const ref = sessionStorage.getItem('race_ref') || null;
          await registerInterest(growthRaceId, ref);
          currentCount++;

          // Record referral if applicable
          if (ref) {
            await recordReferral(ref, growthRaceId);
            sessionStorage.removeItem('race_ref');
          }
        } catch {
          // Silently fail — still show share options
        }
      }

      showConfirmedState();

      // Try native share on mobile
      if (navigator.share) {
        const raceUrl = await getShareUrl();
        try {
          await navigator.share({ title: raceName, text: getShareText(), url: raceUrl });
          return;
        } catch {
          // User cancelled — show fallback row
        }
      }
    });

    // Listen for auth-state-changed (after login via auth modal with "bezim" intent)
    document.addEventListener('auth-state-changed', async () => {
      // Re-check interest state after auth
      const user = await getUser();
      if (user) {
        const alreadyInterested = await hasInterest(growthRaceId);
        if (alreadyInterested) {
          // Interest was registered by the auth modal's post-auth handler
          currentCount = Number(growthSection?.dataset.interestCount ?? 0) + 1;
          showConfirmedState();
        }
      }
      updateShareLinks();
    });

    // Copy link (desktop)
    async function copyToClipboard(labelEl: HTMLElement | null, resetText: string) {
      const raceUrl = await getShareUrl();
      try {
        await navigator.clipboard.writeText(raceUrl);
      } catch {
        const input = document.createElement('input');
        input.value = raceUrl;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }
      if (labelEl) {
        labelEl.textContent = 'Zkopírováno!';
        setTimeout(() => { labelEl.textContent = resetText; }, 2000);
      }
    }

    document.getElementById('copy-link-btn')?.addEventListener('click', () => {
      copyToClipboard(document.getElementById('copy-link-label'), 'Kopírovat odkaz');
    });
    document.getElementById('copy-link-btn-mobile')?.addEventListener('click', () => {
      copyToClipboard(document.getElementById('copy-link-label-mobile'), 'Odkaz');
    });
  </script>
</BaseLayout>
