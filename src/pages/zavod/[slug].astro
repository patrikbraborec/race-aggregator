---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { terrainLabels, terrainDotColors } from '../../lib/types';
import { getRaceBySlug } from '../../lib/supabase';
import CompletenessBadge from '../../components/CompletenessBadge.astro';
import { getCompleteness } from '../../lib/completeness';

const { slug } = Astro.params;
if (!slug) {
  return new Response(null, { status: 404 });
}

const race = await getRaceBySlug(slug);

if (!race) {
  return new Response(null, { status: 404 });
}

const dateFormatted = new Date(race.date_start).toLocaleDateString('cs-CZ', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const dateEndFormatted = race.date_end
  ? new Date(race.date_end).toLocaleDateString('cs-CZ', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const priceText =
  race.price_from && race.price_to
    ? `${race.price_from}–${race.price_to} Kč`
    : race.price_from
      ? `od ${race.price_from} Kč`
      : 'Zdarma';

const completeness = getCompleteness(race);

---

<BaseLayout
  title={race.name}
  description={race.description ?? `${race.name} — ${dateFormatted} v ${race.city}`}
  canonical={`https://zavodyvcr.cz/zavod/${race.slug}`}
>
  <article class="mx-auto max-w-[960px] px-8 py-16 max-md:px-4">
    <!-- Breadcrumb -->
    <nav class="mb-10 font-mono text-xs uppercase tracking-[0.06em] text-text-secondary">
      <a href="/zavody" class="hover:text-accent transition-colors duration-150">Závody</a>
      <span class="mx-2 text-border">/</span>
      <span class="text-text normal-case">{race.name}</span>
    </nav>

    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-6">
      <div>
        <h1 class="font-serif text-[2.5rem] text-primary leading-tight max-md:text-[2rem]">
          {race.name}
        </h1>
        <div class="mt-4 flex flex-wrap items-center gap-4">
          <span class="font-mono text-sm text-text-secondary">
            {dateFormatted}
            {dateEndFormatted && ` – ${dateEndFormatted}`}
          </span>
          {race.time_start && (
            <span class="font-mono text-sm font-semibold text-text">
              Start {race.time_start}
            </span>
          )}
        </div>
        <p class="mt-2 font-mono text-sm text-text-secondary">
          {race.city}{race.region && race.region !== race.city ? `, ${race.region}` : ''}
          {race.venue && ` · ${race.venue}`}
        </p>
      </div>
      <div class="flex flex-col items-end gap-2">
        <div class="flex items-center gap-2">
          <span class={`h-2.5 w-2.5 rounded-full ${terrainDotColors[race.terrain] ?? terrainDotColors.mixed}`}></span>
          <span class="font-mono text-xs font-medium uppercase tracking-[0.06em] text-text-secondary">
            {terrainLabels[race.terrain] ?? race.terrain}
          </span>
        </div>
        <CompletenessBadge race={race} showLabel />
      </div>
    </div>

    <hr class="mt-10 border-border" />

    <!-- Key Info Grid -->
    <div class="grid grid-cols-2 border-b border-border sm:grid-cols-4">
      <div class="border-r border-border p-6 max-sm:border-b max-sm:border-r-0 max-sm:[&:nth-child(odd)]:border-r max-sm:[&:nth-child(odd)]:border-border">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Vzdálenosti</p>
        <div class="mt-3 space-y-1">
          {race.distances.map((d) => (
            <p class="font-mono text-sm font-semibold text-text">{d.label} ({d.km} km)</p>
          ))}
        </div>
      </div>
      <div class="border-r border-border p-6 max-sm:border-b">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Startovné</p>
        <p class="mt-3 font-mono text-sm font-semibold text-text">{priceText}</p>
      </div>
      {race.elevation_gain && (
        <div class="border-r border-border p-6 max-sm:border-r-0">
          <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Převýšení</p>
          <p class="mt-3 font-mono text-sm font-semibold text-text">{race.elevation_gain} m D+</p>
        </div>
      )}
      {race.capacity && (
        <div class="p-6">
          <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Kapacita</p>
          <p class="mt-3 font-mono text-sm font-semibold text-text">{race.capacity.toLocaleString('cs-CZ')} míst</p>
        </div>
      )}
    </div>

    <!-- Description -->
    {race.description && (
      <div class="mt-12">
        <h2 class="font-mono text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">O závodu</h2>
        <p class="mt-4 max-w-2xl text-base text-text leading-relaxed">{race.description}</p>
      </div>
    )}

    <!-- Action Buttons -->
    <div class="mt-12 flex flex-wrap gap-4">
      {race.registration_url && (
        <a
          href={race.registration_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
        >
          Registrace
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      )}
      {race.website && (
        <a
          href={race.website}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-border px-8 py-3.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-text transition-colors duration-150 hover:border-primary hover:text-primary"
        >
          Web závodu
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      )}
    </div>

    <!-- Organizer -->
    {race.organizer && (
      <div class="mt-12 border border-border p-6">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Pořadatel</p>
        <p class="mt-2 text-base font-medium text-text">
          {race.organizer_url ? (
            <a href={race.organizer_url} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-[#D4552F] transition-colors duration-150">
              {race.organizer}
            </a>
          ) : (
            race.organizer
          )}
        </p>
      </div>
    )}

    <!-- Tags -->
    {race.tags.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-3">
        {race.tags.map((tag) => (
          <span class="font-mono text-xs text-text-secondary">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- Completeness info bar -->
    <div class="mt-12 flex items-center justify-between border border-border p-5">
      <div class="flex items-center gap-3">
        <CompletenessBadge race={race} showLabel />
        <span class="font-mono text-[11px] text-text-secondary">({completeness.score} %)</span>
      </div>
      <button
        type="button"
        id="report-btn"
        class="inline-flex items-center gap-2 font-mono text-xs text-text-secondary hover:text-accent transition-colors duration-150"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5" />
        </svg>
        Nahlásit chybu
      </button>
    </div>

    <!-- Report modal -->
    <div
      id="report-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40"
      data-race-id={race.id}
    >
      <div class="mx-4 w-full max-w-md border border-border bg-surface p-8">
        <h3 class="font-mono text-sm font-semibold uppercase tracking-[0.06em] text-primary">Nahlásit chybu</h3>
        <p class="mt-2 text-sm text-text-secondary">Něco nesedí? Dejte nám vědět.</p>

        <form id="report-form" class="mt-6 space-y-4">
          <fieldset>
            <legend class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary mb-3">Co je špatně?</legend>
            <div class="space-y-2">
              {['Špatné datum', 'Špatný popis', 'Závod zrušen', 'Špatná cena', 'Špatná lokace', 'Jiné'].map((reason) => (
                <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
                  <input type="checkbox" name="reasons" value={reason} class="accent-accent h-4 w-4" />
                  {reason}
                </label>
              ))}
            </div>
          </fieldset>

          <div>
            <label class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary" for="report-message">
              Zpráva (volitelné)
            </label>
            <textarea
              id="report-message"
              name="message"
              rows="3"
              class="mt-2 w-full border border-border bg-bg p-3 text-sm text-text placeholder:text-text-secondary/60 focus:border-accent focus:outline-none"
              placeholder="Upřesněte, co je špatně..."
            ></textarea>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-2.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
            >
              Odeslat
            </button>
            <button
              type="button"
              id="report-cancel"
              class="font-mono text-xs text-text-secondary hover:text-text transition-colors duration-150"
            >
              Zrušit
            </button>
          </div>

          <p id="report-status" class="hidden font-mono text-xs"></p>
        </form>
      </div>
    </div>

    <!-- Back -->
    <hr class="mt-8 border-border" />
    <div class="mt-8">
      <a href="/zavody" class="font-mono text-xs text-accent hover:text-[#D4552F] transition-colors duration-150">
        &larr; Zpět na přehled závodů
      </a>
    </div>
  </article>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const COOLDOWN_KEY = 'report_last_submitted';
    const COOLDOWN_MS = 60_000; // 1 minute between reports

    const btn = document.getElementById('report-btn');
    const modal = document.getElementById('report-modal') as HTMLElement;
    const cancel = document.getElementById('report-cancel');
    const form = document.getElementById('report-form') as HTMLFormElement;
    const statusEl = document.getElementById('report-status') as HTMLElement;

    const raceId = modal?.dataset.raceId;

    btn?.addEventListener('click', () => {
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
    });

    function closeModal() {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
    }

    cancel?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const lastSubmitted = Number(localStorage.getItem(COOLDOWN_KEY) || 0);
      if (Date.now() - lastSubmitted < COOLDOWN_MS) {
        statusEl.textContent = 'Nahlášení je možné jednou za minutu. Zkuste to později.';
        statusEl.className = 'font-mono text-xs text-error';
        statusEl.classList.remove('hidden');
        return;
      }

      const formData = new FormData(form);
      const reasons = formData.getAll('reasons');
      const message = formData.get('message');

      if (reasons.length === 0 && !message) {
        statusEl.textContent = 'Vyberte alespoň jeden důvod nebo napište zprávu.';
        statusEl.className = 'font-mono text-xs text-error';
        statusEl.classList.remove('hidden');
        return;
      }

      try {
        const supabase = createClient(
          import.meta.env.PUBLIC_SUPABASE_URL,
          import.meta.env.PUBLIC_SUPABASE_ANON_KEY
        );

        const { error } = await supabase.from('race_reports').insert({
          race_id: raceId,
          reasons: reasons,
          message: message || null,
        });

        if (error) throw error;

        localStorage.setItem(COOLDOWN_KEY, String(Date.now()));
        statusEl.textContent = 'Děkujeme za nahlášení!';
        statusEl.className = 'font-mono text-xs text-success';
        statusEl.classList.remove('hidden');
        setTimeout(closeModal, 1500);
      } catch {
        statusEl.textContent = 'Chyba při odesílání. Zkuste to znovu.';
        statusEl.className = 'font-mono text-xs text-error';
        statusEl.classList.remove('hidden');
      }
    });
  </script>
</BaseLayout>
