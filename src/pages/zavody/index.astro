---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import RaceCard from '../../components/RaceCard.astro';
import { terrainLabels, validTerrains } from '../../lib/types';
import { getRaces, getRegions } from '../../lib/supabase';

const rawTerrain = Astro.url.searchParams.get('teren');
const terrainParam = rawTerrain && validTerrains.has(rawTerrain) ? rawTerrain : null;
const regionParam = Astro.url.searchParams.get('kraj');
const query = Astro.url.searchParams.get('q') ?? undefined;

const [filtered, regions] = await Promise.all([
  getRaces({ terrain: terrainParam ?? undefined, region: regionParam ?? undefined, query }),
  getRegions(),
]);

const terrainTypes = Object.entries(terrainLabels);

const hasFilters = !!(terrainParam || regionParam || query);
---

<BaseLayout
  title="Závody"
  description="Přehled všech běžeckých závodů v České republice. Filtruj podle termínu, terénu, kraje a vzdálenosti."
>
  <section class="mx-auto max-w-[1200px] px-8 py-16 max-md:px-4">
    <!-- Header -->
    <div class="flex items-end justify-between gap-4 max-md:flex-col max-md:items-start">
      <div>
        <h1 class="font-serif text-[2.5rem] text-primary leading-tight max-md:text-[2rem]">Běžecké závody</h1>
        <p class="mt-2 font-mono text-xs uppercase tracking-[0.06em] text-text-secondary">
          {filtered.length} {filtered.length === 1 ? 'závod' : (filtered.length >= 2 && filtered.length < 5) ? 'závody' : 'závodů'} v nabídce
        </p>
      </div>
      {hasFilters && (
        <a
          href="/zavody"
          class="font-mono text-xs text-accent transition-colors duration-150 hover:text-[#D4552F]"
        >
          Zrušit filtry &times;
        </a>
      )}
    </div>

    <hr class="mt-8 border-border" />

    <!-- Filters -->
    <form method="get" class="mt-8 grid grid-cols-[1fr_1fr_1fr_auto_auto] items-end gap-4 max-md:grid-cols-1">
      <div>
        <label for="q" class="block font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary mb-2">Hledat</label>
        <input
          type="text"
          name="q"
          id="q"
          value={query ?? ''}
          placeholder="Název, město..."
          class="w-full border border-border bg-surface px-4 py-3 font-mono text-sm text-text placeholder:text-text-secondary/50 focus:outline-none focus:border-accent transition duration-150"
        />
      </div>
      <div>
        <label for="teren" class="block font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary mb-2">Terén</label>
        <select
          name="teren"
          id="teren"
          class="w-full border border-border bg-surface px-4 py-3 font-mono text-sm text-text focus:outline-none focus:border-accent transition duration-150 appearance-none"
        >
          <option value="">Všechny</option>
          {terrainTypes.map(([value, label]) => (
            <option value={value} selected={terrainParam === value}>
              {label}
            </option>
          ))}
        </select>
      </div>
      <div>
        <label for="kraj" class="block font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary mb-2">Kraj</label>
        <select
          name="kraj"
          id="kraj"
          class="w-full border border-border bg-surface px-4 py-3 font-mono text-sm text-text focus:outline-none focus:border-accent transition duration-150 appearance-none"
        >
          <option value="">Všechny</option>
          {regions.map((r) => (
            <option value={r} selected={regionParam === r}>
              {r}
            </option>
          ))}
        </select>
      </div>
      <button
        type="submit"
        class="bg-accent px-8 py-3 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
      >
        Filtrovat &rarr;
      </button>
    </form>

    <hr class="mt-8 border-border" />

    <!-- Race List -->
    <div class="mt-0">
      {filtered.length > 0 ? (
        filtered.map((race) => <RaceCard race={race} />)
      ) : (
        <div class="border-b border-border py-20 text-center">
          <p class="font-mono text-sm text-text-secondary">Žádné závody neodpovídají zvoleným filtrům.</p>
          <a href="/zavody" class="mt-4 inline-block font-mono text-xs text-accent hover:text-[#D4552F] transition duration-150">
            Zobrazit všechny závody &rarr;
          </a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
