---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import RaceCard from '../components/RaceCard.astro';
import TypewriterSearch from '../components/TypewriterSearch.astro';
import { getUpcomingRaces } from '../lib/supabase';

const upcomingRaces = await getUpcomingRaces(6);
---

<BaseLayout title="Domů">
  <!-- Hero -->
  <section class="mx-auto max-w-[1200px] px-8 pt-16 pb-10 max-md:px-4 max-md:pt-10">
    <div class="max-w-3xl">
      <h1 class="font-serif text-[3.5rem] leading-[1.1] text-primary max-md:text-[2.5rem]">
        Najdi svůj<br />další závod
      </h1>
      <p class="mt-4 max-w-lg text-lg text-text-secondary leading-relaxed">
        Více než 1000 běžeckých závodů v České republice na jednom místě.
      </p>
    </div>

    <!-- Search -->
    <form action="/api/search" method="get" class="mt-8 max-w-2xl">
      <div class="flex border border-border max-sm:flex-col">
        <TypewriterSearch
          name="q"
          class="min-w-0 flex-1 bg-surface px-6 py-4 font-mono text-sm text-text placeholder:text-text-secondary/50 focus:outline-none"
        />
        <button
          type="submit"
          class="shrink-0 bg-accent px-8 py-4 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
          aria-label="Hledat"
        >
          Hledat &rarr;
        </button>
      </div>
      <div class="mt-3 flex flex-wrap gap-2 gap-y-1">
        <a href="/api/search?q=trail+v+Praze" class="font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent">Trail v Praze</a>
        <span class="text-border">/</span>
        <a href="/api/search?q=p%C5%AFlmaraton" class="font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent">Půlmaraton</a>
        <span class="text-border">/</span>
        <a href="/api/search?q=10+km+v+Brn%C4%9B" class="font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent">10 km v Brně</a>
        <span class="text-border">/</span>
        <a href="/zavody?km=50" class="font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent">Ultra</a>
      </div>
    </form>
  </section>

  <!-- Decorative rule -->
  <div class="mx-auto max-w-[1200px] px-8 max-md:px-4">
    <hr class="border-border" />
  </div>

  <!-- Upcoming Races -->
  <section class="mx-auto max-w-[1200px] px-8 pt-8 pb-10 max-md:px-4">
    <div class="flex items-center justify-between">
      <h2 class="font-mono text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">Nejbližší závody</h2>
      <a href="/zavody" class="font-mono text-xs text-accent transition-colors duration-150 hover:text-[#D4552F]">
        Zobrazit všechny &rarr;
      </a>
    </div>
    <div class="mt-4 border-t border-border">
      {upcomingRaces.map((race) => <RaceCard race={race} compact />)}
    </div>
    <div class="mt-6 text-center">
      <a
        href="/zavody"
        class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
      >
        Prozkoumat všechny závody
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
