---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import RaceCard from '../components/RaceCard.astro';
import { terrainLabels, terrainDotColors } from '../lib/types';
import { getUpcomingRaces, getTerrainCounts, getRegions } from '../lib/supabase';

const [upcomingRaces, terrainCounts, regions] = await Promise.all([
  getUpcomingRaces(6),
  getTerrainCounts(),
  getRegions(),
]);

const topTerrains = Object.entries(terrainCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 6);

const totalRaces = Object.values(terrainCounts).reduce((a, b) => a + b, 0);
---

<BaseLayout title="Domů">
  <!-- Hero -->
  <section class="mx-auto max-w-[1200px] px-8 pt-24 pb-16 max-md:px-4 max-md:pt-16">
    <div class="max-w-3xl">
      <h1 class="font-serif text-[3.5rem] leading-[1.1] text-primary max-md:text-[2.5rem]">
        Najdi svůj<br />další závod
      </h1>
      <p class="mt-6 max-w-lg text-lg text-text-secondary leading-relaxed">
        Všechny běžecké závody v České republice na jednom místě.
      </p>
    </div>

    <!-- Search -->
    <form action="/zavody" method="get" class="mt-12 max-w-2xl">
      <div class="flex border border-border">
        <input
          type="text"
          name="q"
          placeholder="Název závodu, město nebo typ terénu..."
          class="flex-1 bg-surface px-6 py-4 font-mono text-sm text-text placeholder:text-text-secondary/50 focus:outline-none"
        />
        <button
          type="submit"
          class="bg-accent px-8 py-4 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
          aria-label="Hledat"
        >
          Hledat &rarr;
        </button>
      </div>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/zavody?teren=trail" class="font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent">Trail</a>
        <span class="text-border">/</span>
        <a href="/zavody?q=Praha" class="font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent">Praha</a>
        <span class="text-border">/</span>
        <a href="/zavody?q=maraton" class="font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent">Maraton</a>
        <span class="text-border">/</span>
        <a href="/zavody?teren=ultra" class="font-mono text-xs text-text-secondary transition-colors duration-150 hover:text-accent">Ultra</a>
      </div>
    </form>
  </section>

  <!-- Decorative rule -->
  <div class="mx-auto max-w-[1200px] px-8 max-md:px-4">
    <hr class="border-border" />
  </div>

  <!-- Stats bar -->
  <section class="mx-auto max-w-[1200px] px-8 py-12 max-md:px-4">
    <div class="grid grid-cols-3 border border-border max-md:grid-cols-1">
      <div class="border-r border-border p-6 max-md:border-b max-md:border-r-0">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Závodů celkem</p>
        <p class="mt-2 font-mono text-3xl font-semibold text-primary">{totalRaces}</p>
      </div>
      <div class="border-r border-border p-6 max-md:border-b max-md:border-r-0">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Typů terénu</p>
        <p class="mt-2 font-mono text-3xl font-semibold text-primary">{Object.keys(terrainCounts).length}</p>
      </div>
      <div class="p-6">
        <p class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary">Krajů</p>
        <p class="mt-2 font-mono text-3xl font-semibold text-primary">{regions.length}</p>
      </div>
    </div>
  </section>

  <!-- Terrain Categories -->
  <section class="mx-auto max-w-[1200px] px-8 pt-4 pb-12 max-md:px-4">
    <div class="flex items-center justify-between">
      <h2 class="font-mono text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">Podle terénu</h2>
      <a href="/zavody" class="font-mono text-xs text-accent transition-colors duration-150 hover:text-[#D4552F]">
        Všechny typy &rarr;
      </a>
    </div>
    <div class="mt-6 grid grid-cols-3 border border-border max-md:grid-cols-2">
      {topTerrains.map(([key, count], i) => (
        <a
          href={`/zavody?teren=${key}`}
          class:list={[
            'group flex items-center gap-3 p-5 transition-colors duration-150 hover:bg-accent-light',
            i < topTerrains.length - (topTerrains.length % 3 === 0 ? 3 : topTerrains.length % 3) ? 'border-b border-border' : '',
            (i + 1) % 3 !== 0 ? 'border-r border-border max-md:border-r-0' : '',
            (i + 1) % 2 !== 0 ? 'max-md:border-r max-md:border-border' : '',
          ]}
        >
          <span class={`h-2 w-2 rounded-full ${terrainDotColors[key] ?? terrainDotColors.mixed}`}></span>
          <span class="font-mono text-sm font-medium text-text group-hover:text-accent transition-colors duration-150">
            {terrainLabels[key] ?? key}
          </span>
          <span class="font-mono text-xs text-text-secondary ml-auto">{count}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Decorative rule -->
  <div class="mx-auto max-w-[1200px] px-8 max-md:px-4">
    <hr class="border-border" />
  </div>

  <!-- Upcoming Races -->
  <section class="mx-auto max-w-[1200px] px-8 pt-12 pb-20 max-md:px-4">
    <div class="flex items-center justify-between">
      <h2 class="font-mono text-xs font-semibold uppercase tracking-[0.08em] text-text-secondary">Nejbližší závody</h2>
      <a href="/zavody" class="font-mono text-xs text-accent transition-colors duration-150 hover:text-[#D4552F]">
        Zobrazit všechny &rarr;
      </a>
    </div>
    <div class="mt-6 border-t border-border">
      {upcomingRaces.map((race) => <RaceCard race={race} compact />)}
    </div>
    <div class="mt-10 text-center">
      <a
        href="/zavody"
        class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
      >
        Prozkoumat všechny závody
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
