---
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div class="mx-auto max-w-[1200px] px-8 py-10 max-md:px-4">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-text-secondary">
        &copy; {year} ZávodyvČR. Všechna práva vyhrazena.
      </p>
      <div class="flex gap-6 text-sm text-text-secondary">
        <a href="/o-nas" class="transition-colors duration-150 hover:text-text">O nás</a>
        <a href="/kontakt" class="transition-colors duration-150 hover:text-text">Kontakt</a>
      </div>
    </div>
  </div>
</footer>
