---
import AuthModal from './AuthModal.astro';

const navItems = [
  { label: 'Závody', href: '/zavody' },
];

const currentPath = Astro.url.pathname;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-[1200px] items-center justify-between px-8 py-5 max-md:px-4">
    <a href="/" class="group flex items-center gap-2">
      <span class="font-serif text-2xl leading-none text-primary translate-y-[1px]">Závody</span>
      <span class="font-mono text-xs font-medium uppercase leading-none tracking-[0.08em] text-accent">v ČR</span>
    </a>
    <ul class="flex items-center gap-8 max-md:gap-4">
      {navItems.map((item) => {
        const isActive = currentPath.startsWith(item.href);
        return (
          <li class="flex items-center">
            <a
              href={item.href}
              class:list={[
                'inline-flex items-center leading-none font-mono text-xs font-medium uppercase tracking-[0.06em] transition-colors duration-150',
                isActive
                  ? 'text-primary underline underline-offset-4 decoration-accent decoration-2'
                  : 'text-text-secondary hover:text-primary',
              ]}
            >
              {item.label}
            </a>
          </li>
        );
      })}
      <li class="flex items-center">
        <button
          type="button"
          id="missing-race-btn"
          class="inline-flex items-center gap-2 leading-none font-mono text-xs font-medium uppercase tracking-[0.06em] text-accent transition-colors duration-150 hover:text-[#D4552F] max-md:hidden"
        >
          <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Chybí ti závod?
        </button>
      </li>

      <!-- Auth nav (client-side controlled) -->
      <li id="auth-nav" class="flex items-center opacity-0 transition-opacity duration-200">
        <!-- Logged out state (default) -->
        <button
          type="button"
          id="header-login-btn"
          class="inline-flex items-center gap-2 leading-none font-mono text-xs font-medium uppercase tracking-[0.06em] text-text-secondary hover:text-primary transition-colors duration-150"
        >
          <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
          <span class="max-md:hidden">Přihlásit se</span>
        </button>
        <!-- Logged in state (hidden by default) -->
        <div id="user-nav" class="hidden items-center gap-6 max-md:gap-4">
          <a
            href="/moje-zavody"
            id="header-my-races"
            class:list={[
              'inline-flex items-center gap-2 leading-none font-mono text-xs font-medium uppercase tracking-[0.06em] transition-colors duration-150',
              currentPath === '/moje-zavody'
                ? 'text-primary underline underline-offset-4 decoration-accent decoration-2'
                : 'text-text-secondary hover:text-primary',
            ]}
          >
            <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.841m2.699-11.592L3.75 21.75" />
            </svg>
            <span class="max-md:hidden">Moje závody</span>
          </a>
          <button
            type="button"
            id="header-logout-btn"
            class="inline-flex items-center leading-none font-mono text-xs font-medium uppercase tracking-[0.06em] text-text-secondary hover:text-primary transition-colors duration-150"
          >
            <span class="max-md:hidden">Odhlásit se</span>
            <svg class="h-3.5 w-3.5 shrink-0 md:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
            </svg>
          </button>
        </div>
      </li>
    </ul>
  </nav>
</header>

<!-- Missing race modal -->
<div
  id="missing-race-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40"
  data-supabase-url={supabaseUrl}
  data-supabase-key={supabaseKey}
>
  <div class="mx-4 w-full max-w-md border border-border bg-surface p-8">
    <h3 class="font-mono text-sm font-semibold uppercase tracking-[0.06em] text-primary">Chybí ti závod?</h3>
    <p class="mt-2 text-sm text-text-secondary">Pošli nám odkaz na závod, který v seznamu chybí.</p>

    <form id="missing-race-form" class="mt-6 space-y-4">
      <div>
        <label class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary" for="missing-race-url">
          Odkaz na závod
        </label>
        <input
          type="url"
          id="missing-race-url"
          name="url"
          required
          class="mt-2 w-full border border-border bg-bg p-3 text-sm text-text placeholder:text-text-secondary/60 focus:border-accent focus:outline-none"
          placeholder="https://example.com/zavod"
        />
      </div>

      <div>
        <label class="font-mono text-[11px] font-medium uppercase tracking-[0.08em] text-text-secondary" for="missing-race-message">
          Zpráva (volitelné)
        </label>
        <textarea
          id="missing-race-message"
          name="message"
          rows="3"
          class="mt-2 w-full border border-border bg-bg p-3 text-sm text-text placeholder:text-text-secondary/60 focus:border-accent focus:outline-none"
          placeholder="Případně doplň další informace..."
        ></textarea>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-2.5 font-mono text-xs font-semibold uppercase tracking-[0.06em] text-white transition-colors duration-150 hover:bg-[#D4552F]"
        >
          Odeslat
        </button>
        <button
          type="button"
          id="missing-race-cancel"
          class="font-mono text-xs text-text-secondary hover:text-text transition-colors duration-150"
        >
          Zrušit
        </button>
      </div>

      <p id="missing-race-status" class="hidden font-mono text-xs"></p>
    </form>
  </div>
</div>

<!-- Auth modal (global, available on every page) -->
<AuthModal />

<script>
  import { getUser, signOut } from '../lib/auth';

  // --- Auth nav state ---
  const authNav = document.getElementById('auth-nav') as HTMLElement;
  const loginBtn = document.getElementById('header-login-btn') as HTMLElement;
  const userNav = document.getElementById('user-nav') as HTMLElement;
  const logoutBtn = document.getElementById('header-logout-btn');

  async function updateAuthNav() {
    const user = await getUser();
    if (user) {
      loginBtn.classList.add('hidden');
      userNav.classList.remove('hidden');
      userNav.classList.add('flex');
    } else {
      loginBtn.classList.remove('hidden');
      userNav.classList.add('hidden');
      userNav.classList.remove('flex');
    }
    // Fade in after check
    authNav.classList.remove('opacity-0');
    authNav.classList.add('opacity-100');
  }

  updateAuthNav();

  // Listen for auth state changes from AuthModal
  document.addEventListener('auth-state-changed', () => {
    updateAuthNav();
  });

  // Login button opens auth modal
  loginBtn?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { intent: 'login' } }));
  });

  // Logout
  logoutBtn?.addEventListener('click', async () => {
    await signOut();
    document.dispatchEvent(new CustomEvent('auth-state-changed', { detail: { user: null } }));
    // Redirect to home if on a protected page
    if (window.location.pathname === '/moje-zavody') {
      window.location.href = '/zavody';
    }
  });

  // --- Missing race modal (unchanged logic) ---
  const btn = document.getElementById('missing-race-btn');
  const modal = document.getElementById('missing-race-modal') as HTMLElement;
  const cancel = document.getElementById('missing-race-cancel');
  const form = document.getElementById('missing-race-form') as HTMLFormElement;
  const statusEl = document.getElementById('missing-race-status') as HTMLElement;

  const supabaseUrl = modal?.dataset.supabaseUrl;
  const supabaseKey = modal?.dataset.supabaseKey;

  btn?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  });

  function closeModal() {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  }

  cancel?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const url = formData.get('url') as string;
    const message = formData.get('message') as string;

    if (!url) {
      statusEl.textContent = 'Zadej odkaz na závod.';
      statusEl.className = 'font-mono text-xs text-error';
      statusEl.classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/missing_race_reports`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': supabaseKey!,
          'Authorization': `Bearer ${supabaseKey}`,
        },
        body: JSON.stringify({
          url: url,
          message: message || null,
        }),
      });

      if (res.ok || res.status === 201) {
        statusEl.textContent = 'Děkujeme! Závod prověříme.';
        statusEl.className = 'font-mono text-xs text-success';
        statusEl.classList.remove('hidden');
        form.reset();
        setTimeout(closeModal, 1500);
      } else {
        throw new Error('Failed');
      }
    } catch {
      statusEl.textContent = 'Chyba při odesílání. Zkuste to znovu.';
      statusEl.className = 'font-mono text-xs text-error';
      statusEl.classList.remove('hidden');
    }
  });
</script>
