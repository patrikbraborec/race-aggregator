---
import type { Race } from '../lib/types';
import { terrainLabels, terrainDotColors } from '../lib/types';
import CompletenessBadge from './CompletenessBadge.astro';

interface Props {
  race: Race;
  compact?: boolean;
}

const { race, compact = false } = Astro.props;

const dateFormatted = new Date(race.date_start).toLocaleDateString('cs-CZ', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const distanceText = race.distances
  .map((d) => (d.km >= 1 ? `${d.km} km` : `${d.km * 1000} m`))
  .join(' / ');
const distanceLabel = distanceText || 'Neuvedeno';

---

<a
  href={`/zavod/${race.slug}`}
  class="group block border-b border-border transition-colors duration-150 hover:bg-accent-light"
>
  <div class="flex items-center gap-6 px-6 py-5 max-md:flex-col max-md:items-start max-md:gap-3 max-md:px-4">
    <!-- Terrain dot + Name -->
    <div class="flex min-w-0 flex-1 items-center gap-3 overflow-hidden">
      <span class={`h-2 w-2 shrink-0 rounded-full ${terrainDotColors[race.terrain] ?? terrainDotColors.mixed}`}></span>
      <h3 class="truncate max-md:whitespace-normal max-md:line-clamp-2 text-base font-semibold text-text group-hover:text-accent transition-colors duration-150">
        {race.name}
      </h3>
    </div>

    <!-- Date + City (mono) -->
    <div class="flex items-center gap-6 max-md:ml-5">
      <span class="font-mono text-xs font-medium uppercase tracking-wide text-text-secondary">
        {dateFormatted}
      </span>
      <span class="font-mono text-xs text-text-secondary">
        {race.city}{race.region && race.region !== race.city ? `, ${race.region}` : ''}
      </span>
    </div>

    <!-- Distance + Terrain (mono) -->
    <div class="flex items-center gap-4 max-md:ml-5">
      <span class="max-w-[10rem] truncate font-mono text-xs font-semibold text-text" title={distanceLabel}>
        {distanceLabel}
      </span>
      <span class="font-mono text-[11px] uppercase tracking-[0.06em] text-text-secondary">
        {terrainLabels[race.terrain] ?? race.terrain}
      </span>
    </div>

    <!-- Completeness + Arrow -->
    <div class="flex items-center gap-3 max-md:hidden">
      <CompletenessBadge race={race} />
      <svg class="h-4 w-4 shrink-0 text-text-secondary/40 group-hover:text-accent transition-colors duration-150" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </div>
  </div>


</a>
