---
import type { Race } from '../lib/types';
import { terrainLabels } from '../lib/mock-data';

interface Props {
  race: Race;
  compact?: boolean;
}

const { race, compact = false } = Astro.props;

const dateFormatted = new Date(race.date_start).toLocaleDateString('cs-CZ', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const distanceText = race.distances
  .map((d) => (d.km >= 1 ? `${d.km} km` : `${d.km * 1000} m`))
  .join(' / ');

const priceText =
  race.price_from && race.price_to
    ? `${race.price_from}–${race.price_to} Kč`
    : race.price_from
      ? `od ${race.price_from} Kč`
      : null;

const terrainBadge: Record<string, string> = {
  road: 'bg-bg text-text-secondary',
  trail: 'bg-[#E8F5E9] text-success',
  ultra: 'bg-[#F3E8FF] text-[#6B21A8]',
  cross: 'bg-[#FEF3C7] text-accent',
  obstacle: 'bg-[#FEE2E2] text-error',
  mixed: 'bg-bg text-text-secondary',
};
---

<a
  href={`/zavod/${race.slug}`}
  class="group block rounded-2xl bg-surface p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04),0_1px_2px_rgba(0,0,0,0.02)] transition-shadow duration-150 ease-in-out hover:shadow-[0_4px_12px_rgba(0,0,0,0.06)]"
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <h3 class="text-lg font-semibold tracking-[-0.01em] text-text group-hover:text-primary transition-colors duration-150 truncate">
        {race.name}
      </h3>
      <p class="mt-1.5 text-sm text-text-secondary">
        {dateFormatted} · {race.city}{race.region && race.region !== race.city ? `, ${race.region}` : ''}
      </p>
    </div>
    <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ${terrainBadge[race.terrain] ?? terrainBadge.mixed}`}>
      {terrainLabels[race.terrain] ?? race.terrain}
    </span>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-sm text-text-secondary">
    <span class="flex items-center gap-1.5">
      <svg class="h-[18px] w-[18px] text-text-secondary/60" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
      </svg>
      {distanceText}
    </span>
    {priceText && (
      <span class="flex items-center gap-1.5">
        <svg class="h-[18px] w-[18px] text-text-secondary/60" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
        </svg>
        {priceText}
      </span>
    )}
    {race.elevation_gain && (
      <span class="flex items-center gap-1.5">
        <svg class="h-[18px] w-[18px] text-text-secondary/60" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m3 16.5 7.5-12 4.5 7.5 6-6" />
        </svg>
        {race.elevation_gain} m
      </span>
    )}
  </div>

  {!compact && race.tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {race.tags.slice(0, 3).map((tag) => (
        <span class="rounded-full bg-bg px-2.5 py-0.5 text-xs font-medium text-text-secondary">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
